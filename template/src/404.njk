---js
{
  layout: "base.njk",
  permalink: "404.html",
  eleventyExcludeFromCollections: true,
  // GitHub Pages serves 404.html for any unknown path. pg carries the fields
  // base.njk reads; the slug matches no nav entry, so no link is highlighted.
  eleventyComputed: {
    pg: (data) => ({
      slug: "404",
      href: "/404.html",
      metaTitle: "Page not found — " + data.site.name,
      metaDescription: "This page doesn't exist on " + data.site.name + ".",
    }),
  },
}
---
    <section class="px-4 py-24 md:py-32 text-center">
      <div class="max-w-xl mx-auto">
        <p class="text-7xl md:text-8xl font-bold heading-gradient mb-6">404</p>
        <h1 class="text-2xl md:text-3xl font-bold text-bone mb-3">Page not found</h1>
        <p class="text-sm text-ash leading-relaxed mb-10">The page you're looking for doesn't exist or has moved.</p>
        <a href="/" class="inline-block px-6 py-3 rounded-md bg-accent text-bone text-base font-semibold border border-accent/40 hover:bg-accent2-bright hover:brightness-110 transition">Back to home</a>
      </div>
    </section>
